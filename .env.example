# App Configuration
APP_NAME=fellaw
APP_VERSION=1.0.0
SECRET_KEY=your-secret-key-here-change-in-production

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://fellaw:fellaw_secure_2024@localhost:5433/fellaw_db
POSTGRES_USER=fellaw
POSTGRES_PASSWORD=fellaw_secure_2024
POSTGRES_DB=fellaw_db

# Azure AI - West Europe (Chat: gpt-4.1-mini)
AZURE_WEU_ENDPOINT=your-azure-westeurope-endpoint
AZURE_WEU_KEY=your-azure-westeurope-api-key
AZURE_WEU_API_VERSION=2025-01-01-preview
AZURE_CHAT_MODEL=gpt-4.1-mini

# Azure AI - Sweden Central (Embeddings)
AZURE_SE_ENDPOINT=your-azure-sweden-endpoint
AZURE_SE_KEY=your-azure-sweden-api-key
AZURE_SE_API_VERSION=2025-04-01-preview
AZURE_EMBEDDING_MODEL=text-embedding-3-large
AZURE_EMBEDDING_DIMENSIONS=1536

# Azure Document Intelligence
DOCINTEL_ENDPOINT=your-azure-docintel-endpoint
DOCINTEL_KEY=your-azure-docintel-key

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:80","http://localhost","http://frontend"]

# File upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB
