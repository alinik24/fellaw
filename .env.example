# =============================================================================
# fellaw - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=fellaw
APP_VERSION=1.0.0
SECRET_KEY=your-secret-key-change-this-to-random-value-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# For Docker: Use service name 'postgres' as hostname
# For local dev: Use 'localhost' with appropriate port
DATABASE_URL=postgresql+asyncpg://fellaw:fellaw_secure_2024@postgres:5432/fellaw_db
POSTGRES_USER=fellaw
POSTGRES_PASSWORD=fellaw_secure_2024
POSTGRES_DB=fellaw_db

# ── AI Provider Configuration ────────────────────────────────────────────────
# Supported providers: openai, azure, anthropic, google, cohere, local
# Set your primary provider here
AI_PROVIDER=openai

# ── Chat Model Configuration ─────────────────────────────────────────────────
# Model to use for conversational AI (chat, narrative generation, etc.)
CHAT_MODEL=gpt-4-turbo-preview
CHAT_TEMPERATURE=0.3
CHAT_MAX_TOKENS=2000

# ── Embedding Model Configuration ────────────────────────────────────────────
# Model to use for text embeddings (RAG, semantic search)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# ═════════════════════════════════════════════════════════════════════════════
# Provider-Specific API Keys
# Fill in the section for your chosen AI_PROVIDER
# ═════════════════════════════════════════════════════════════════════════════

# ── OpenAI (provider: openai) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=  # Optional: Your OpenAI organization ID
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: Custom base URL

# ── Azure OpenAI (provider: azure) ───────────────────────────────────────────
# For chat/completion models
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_CHAT_DEPLOYMENT=gpt-4-deployment-name

# For embeddings (can be same or different Azure instance)
AZURE_EMBEDDING_ENDPOINT=https://your-resource.openai.azure.com
AZURE_EMBEDDING_API_KEY=your-azure-api-key-here
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-deployment-name

# ── Anthropic Claude (provider: anthropic) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# Recommended models: claude-3-5-sonnet-20241022, claude-3-opus-20240229

# ── Google AI / Vertex AI (provider: google) ─────────────────────────────────
GOOGLE_API_KEY=your-google-ai-api-key-here
GOOGLE_PROJECT_ID=your-gcp-project-id  # For Vertex AI
GOOGLE_LOCATION=us-central1  # For Vertex AI
# Recommended models: gemini-1.5-pro, gemini-1.5-flash

# ── Cohere (provider: cohere) ────────────────────────────────────────────────
COHERE_API_KEY=your-cohere-api-key-here
# Recommended models: command-r-plus, embed-multilingual-v3.0

# ── Local / Ollama (provider: local) ─────────────────────────────────────────
LOCAL_MODEL_URL=http://localhost:11434  # Ollama default
LOCAL_CHAT_MODEL=llama3.1:8b
LOCAL_EMBEDDING_MODEL=nomic-embed-text

# ── Hugging Face (provider: huggingface) ─────────────────────────────────────
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here
HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ── Azure Document Intelligence ──────────────────────────────────────────────
# For OCR and document analysis
DOCINTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
DOCINTEL_API_KEY=your-azure-document-intelligence-key-here

# ── CORS Configuration ───────────────────────────────────────────────────────
# Comma-separated list or JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:80","http://localhost","http://frontend"]

# ── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB

# ── Optional: Advanced Configuration ─────────────────────────────────────────
# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Cache (Redis - optional)
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=false
CACHE_TTL=3600  # seconds

# Email (for notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@fellaw.com

# External Services (optional)
SENTRY_DSN=  # Error tracking
ANALYTICS_ID=  # Google Analytics, etc.

# ═════════════════════════════════════════════════════════════════════════════
# Development / Testing
# ═════════════════════════════════════════════════════════════════════════════
DEBUG=false
TESTING=false
