# =============================================================================
# FelLaw - Environment Configuration Template
# =============================================================================
# Copy this file to create your environment files:
# - Backend: backend/.env
# - Frontend: frontend/.env

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=fellaw
APP_VERSION=1.0.0
SECRET_KEY=your-secret-key-min-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://fellaw:your_password@localhost:5432/fellaw_db
POSTGRES_USER=fellaw
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=fellaw_db

# ── AI Provider Configuration ────────────────────────────────────────────────
AI_PROVIDER=openai
CHAT_MODEL=gpt-4-turbo-preview
CHAT_TEMPERATURE=0.3
CHAT_MAX_TOKENS=2000
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# ── OpenRouter (Image Analysis) ──────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_VISION_MODEL=anthropic/claude-3.5-sonnet

# ── Azure OpenAI (Optional) ──────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_CHAT_DEPLOYMENT=
AZURE_EMBEDDING_ENDPOINT=
AZURE_EMBEDDING_API_KEY=
AZURE_EMBEDDING_DEPLOYMENT=

# ── Azure Document Intelligence (Optional) ───────────────────────────────────
DOCINTEL_ENDPOINT=
DOCINTEL_API_KEY=

# ── CORS Configuration ───────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB

# ── Logging & Debug ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
