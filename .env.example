# =============================================================================
# FelLaw - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update with your actual values
# For Docker: This file is used by docker-compose.yml
# For local development: Copy to backend/.env and frontend/.env

# =============================================================================
# Docker Compose Configuration
# =============================================================================
# Note: FelLaw uses an existing shared PostgreSQL instance
# Database: fellaw (auto-created)
# Credentials: postgres/postgres (from shared instance)

BACKEND_PORT=8000
FRONTEND_PORT=80

# =============================================================================
# Application Configuration
# =============================================================================
APP_NAME=fellaw
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# Security & Authentication
# =============================================================================
SECRET_KEY=your-secret-key-min-32-characters-MUST-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =============================================================================
# Database Configuration
# =============================================================================
# Connects to shared PostgreSQL instance with fellaw database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/fellaw

# For local development: Use localhost
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fellaw

# =============================================================================
# API Configuration
# =============================================================================
API_V1_PREFIX=/api/v1
PROJECT_NAME=FelLaw

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost","http://frontend"]

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_API_URL=http://localhost:8000

# =============================================================================
# AI Provider Configuration
# =============================================================================
AI_PROVIDER=openai
CHAT_MODEL=gpt-4-turbo-preview
CHAT_TEMPERATURE=0.3
CHAT_MAX_TOKENS=2000
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (Optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenRouter (Image Analysis) - Optional
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_VISION_MODEL=anthropic/claude-3.5-sonnet

# =============================================================================
# Azure OpenAI (Optional)
# =============================================================================
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_CHAT_DEPLOYMENT=
AZURE_EMBEDDING_ENDPOINT=
AZURE_EMBEDDING_API_KEY=
AZURE_EMBEDDING_DEPLOYMENT=

# =============================================================================
# Azure Document Intelligence (Optional)
# =============================================================================
DOCINTEL_ENDPOINT=
DOCINTEL_API_KEY=

# =============================================================================
# File Upload Configuration
# =============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB

# =============================================================================
# Logging & Debug
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Adminer (Database Management - runs on existing container)
# =============================================================================
# Access at: http://localhost:8080
# Server: postgres
# Username: postgres
# Password: postgres
# Database: fellaw

# =============================================================================
# Production Settings
# =============================================================================
# When deploying to production, update these values:
# - ENVIRONMENT=production
# - DEBUG=false
# - Use strong, randomly generated SECRET_KEY (min 32 chars)
# - Use strong POSTGRES_PASSWORD
# - Update BACKEND_CORS_ORIGINS with your domain
# - Update VITE_API_URL with your production API URL
# - Add your production API keys
