# Backend Environment Configuration
# Copy this to backend/.env and fill in your values

APP_NAME=fellaw
APP_VERSION=1.0.0
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=postgresql+asyncpg://fellaw:your_password@localhost:5432/fellaw_db
POSTGRES_USER=fellaw
POSTGRES_PASSWORD=your_password
POSTGRES_DB=fellaw_db

# AI Configuration
AI_PROVIDER=openai
CHAT_MODEL=gpt-4-turbo-preview
CHAT_TEMPERATURE=0.3
CHAT_MAX_TOKENS=2000
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# OpenRouter for Vision/OCR
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_VISION_MODEL=anthropic/claude-3.5-sonnet

# Azure Document Intelligence (optional)
DOCINTEL_ENDPOINT=
DOCINTEL_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=50MB

# Logging
LOG_LEVEL=INFO
DEBUG=false
TESTING=false
